# Copy to .env for local development:  cp .env.example .env
#
# Local dev — SQLite (no setup, provider auto-selected as sqlite):
DATABASE_URL="file:./dev.db"

# App password gate — protects every page behind a single shared password.
APP_PASSWORD="choose-a-password"
# Signing secret for the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-long-random-string"
#
# Production is provisioned on Vercel (Neon Postgres) — DATABASE_URL is injected
# automatically there. Set APP_PASSWORD and AUTH_SECRET as project env vars.
