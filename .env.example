# Copy to .env for local development:  cp .env.example .env
#
# Local dev — SQLite (no setup, provider auto-selected as sqlite):
DATABASE_URL="file:./dev.db"
#
# Production is provisioned on Vercel (Neon Postgres) — DATABASE_URL is injected
# automatically there, and the provider auto-switches to postgresql. Nothing to
# set here for deployment.
